# GEMINI_API_KEY: Required for Gemini AI API calls (Music Lab features).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Supabase configuration for backend database connectivity
# Project: malhaarmusicsocietyofmlnc@gmail.com's Project
# Project ID: irolbvsqyshihomfzflk
SUPABASE_HOST=db.irolbvsqyshihomfzflk.supabase.co

# IMPORTANT: Set this to the Database Password you created when provisioning your Supabase project.
# This enables direct PostgreSQL connectivity via Drizzle ORM (port 6543 pooler).
# If left empty, the app falls back to local db.json file storage.
SUPABASE_DB_PASSWORD=

# Supabase REST API connection (fallback for when direct DB connection is unavailable)
SUPABASE_URL=https://irolbvsqyshihomfzflk.supabase.co
# Set this to your Supabase service_role key (a JWT starting with eyJ...)
# NOTE: This is NOT the database password — it's the API key from Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=
